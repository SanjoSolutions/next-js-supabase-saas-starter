# Supabase
# Get these from your project settings > API
# https://app.supabase.com/project/_/settings/api
# For local dev: run `npx supabase start` and use the output values
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (Billing)
STRIPE_SECRET_KEY=your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PRICE_ID=your-stripe-price-id

# Stripe Connect (Marketplace Payments)
STRIPE_CONNECT_WEBHOOK_SECRET=your-stripe-connect-webhook-secret

# Marketplace
CRON_SECRET=your-cron-secret-for-matching-engine
MARKETPLACE_PLATFORM_FEE_PERCENT=10

# Admin Dashboard
# Comma-separated Supabase user IDs that have platform admin access
ADMIN_USER_IDS=

# Social Auth
# Configure Google and GitHub OAuth providers in Supabase Dashboard > Auth > Providers
# No env vars needed here — Supabase handles the OAuth flow
